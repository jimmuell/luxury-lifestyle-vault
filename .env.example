# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=           # server-only — never use NEXT_PUBLIC_ prefix

# ─── App URL ─────────────────────────────────────────────────────────────────
# Required. Used for email links, auth redirects, and server-side URL construction.
# Set to your Vercel deployment URL (or http://localhost:3000 for local dev).
NEXT_PUBLIC_APP_URL=

# ─── Stripe ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=                   # server-only
STRIPE_WEBHOOK_SECRET=               # server-only

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=                      # server-only
RESEND_FROM_EMAIL=                   # optional; default: noreply@luxurylifestylevault.com (verified Resend domain)
RESEND_DEV_MODE=                     # optional; set to "true" to capture emails in dev_email_inbox instead of sending (auto-enabled when RESEND_API_KEY is absent)

# ─── Anthropic (AI search + photo categorization) ────────────────────────────
ANTHROPIC_API_KEY=                   # server-only
AI_CATEGORIZATION_MODEL=             # optional; default: claude-haiku-4-5-20251001

# ─── Sentry (error monitoring) ────────────────────────────────────────────────
# Required in Vercel prod/preview for error monitoring to work; absent = no-op.
NEXT_PUBLIC_SENTRY_DSN=              # public; from Sentry project → Client Keys
SENTRY_DSN=                          # server-only; same value as NEXT_PUBLIC_SENTRY_DSN
NEXT_PUBLIC_VERCEL_ENV=              # optional; set to VERCEL_ENV value in Vercel env settings (production/preview/development)
# Build-time only — set in Vercel project settings, not at runtime:
SENTRY_AUTH_TOKEN=                   # server-only; enables source map upload (optional)
SENTRY_ORG=                          # server-only; your Sentry org slug
SENTRY_PROJECT=                      # server-only; your Sentry project slug

# ─── Twilio (SMS — installed, not yet wired) ──────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=                   # server-only
TWILIO_PHONE_NUMBER=

# ─── Inngest (background jobs) ────────────────────────────────────────────────
# Read automatically by the Inngest SDK — not referenced by name in app code.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=                 # server-only

# ─── Pexels (seed photo fetch) ────────────────────────────────────────────────
PEXELS_API_KEY=                      # server-only

# ─── Seed / dev tools ─────────────────────────────────────────────────────────
# Server-only security boundary for destructive seed/reset operations.
# Set to "true" ONLY in local dev and the test/staging Vercel project.
# Must NOT be set in the production Vercel project — the seed page 404s and
# all seed/reset actions throw when this is absent or not "true".
# Do NOT use a NEXT_PUBLIC_ prefix — this must never enter the client bundle.
SEED_TOOLS_ENABLED=

# ─── Demo login UI (cosmetic only) ────────────────────────────────────────────
# Controls the quick-login dropdown on the sign-in page. Public/cosmetic — not
# a security boundary. Independent of SEED_TOOLS_ENABLED.
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=

# ─── Dev admin quick-login ────────────────────────────────────────────────────
NEXT_PUBLIC_DEV_ADMIN_EMAIL=
